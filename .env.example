# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# MongoDB local connection (default)
DATABASE_URL="mongodb://localhost:27017/mmdss"

# Or with authentication:
# DATABASE_URL="mongodb://username:password@localhost:27017/mmdss?authSource=admin"

# Or MongoDB Atlas (cloud):
# DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/mmdss"

# NextAuth Configuration
NEXTAUTH_SECRET="generate-a-secure-random-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Optional: For production
# NEXTAUTH_URL="https://yourdomain.com"
